# ── Database ────────────────────────────────────────────────────────────────
# SQLite file, relative to the prisma/ directory.
DATABASE_URL="file:./dev.db"

# ── Auth (required) ───────────────────────────────────────────────────────────
# Secret used to sign session JWTs. Use a long, random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# ── Email — license reminders (optional) ──────────────────────────────────────
# Only needed if you use the /api/cron/license-reminders job. Any SMTP provider.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="TransitOps <no-reply@transitops.local>"

# ── Cron (optional) ───────────────────────────────────────────────────────────
# Shared secret required in the `x-cron-secret` header to trigger the reminder job.
CRON_SECRET=""
